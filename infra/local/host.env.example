# Environment for Java services launched on the host (not consumed by Docker Compose).
SPANNER_PROJECT=local-project
SPANNER_INSTANCE=local-instance
SPANNER_DATABASE=local-db
SPANNER_EMULATOR_HOST=localhost:9010
SPANNER_EMULATOR_ENABLED=true

KAFKA_BOOTSTRAP_SERVERS=localhost:29092
REDIS_HOST=localhost
REDIS_PORT=6379
ELASTICSEARCH_URL=http://localhost:9200
CATALOG_BASE_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=local
# common-db owns emulator clients locally; this prevents Spring Cloud GCP from requesting ADC.
SPRING_AUTOCONFIGURE_EXCLUDE=com.google.cloud.spring.autoconfigure.spanner.GcpSpannerAutoConfiguration,com.google.cloud.spring.autoconfigure.spanner.SpannerTransactionManagerAutoConfiguration
