SPANNER_PROJECT=local-project
SPANNER_INSTANCE=local-instance
SPANNER_DATABASE=local-db
# This file is consumed by Docker Compose. `spanner:9010` is a container-network address.
SPANNER_EMULATOR_HOST=spanner:9010

# Application configuration reads KAFKA_BOOTSTRAP_SERVERS. This compose value is only for
# container-side tooling; host-run Java services use infra/local/host.env.example instead.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INTERNAL=http://elasticsearch:9200

